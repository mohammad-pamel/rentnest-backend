model User {
  id String @id @default(uuid())

  name String

  email String @unique

  password String

  phone String?

  profileImage String?

  role Role

  status UserStatus @default(ACTIVE)

  isDeleted Boolean @default(false)

  deletedAt DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  properties Property[]

  rentalRequests RentalRequest[]

  reviews Review[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@map("users")
}
