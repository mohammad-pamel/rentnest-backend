model Review {
  id String @id @default(uuid())

  rating  Int
  comment String

  tenantId   String
  propertyId String

  tenant   User     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([propertyId])
  @@index([tenantId])
  @@map("reviews")
}
